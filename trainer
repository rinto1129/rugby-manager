<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rugby Manager - トレーナー</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--blue:#185FA5;--blue-bg:#E6F1FB;--green:#1D9E75;--green-bg:#E1F5EE;--red:#A32D2D;--red-bg:#FCEBEB;--amber:#854F0B;--amber-bg:#FAEEDA;--purple:#534AB7;--purple-bg:#EEEDFE;--bg-primary:#ffffff;--bg-secondary:#f5f5f0;--bg-tertiary:#eeeee8;--text-primary:#1a1a1a;--text-secondary:#6b6b65;--text-tertiary:#9b9b95;--border-secondary:rgba(0,0,0,0.2);--border-tertiary:rgba(0,0,0,0.1);--font-sans:-apple-system,BlinkMacSystemFont,'Segoe UI','Noto Sans JP',sans-serif;--radius:8px;--radius-lg:12px}
@media(prefers-color-scheme:dark){:root{--bg-primary:#1e1e1e;--bg-secondary:#2a2a2a;--bg-tertiary:#222222;--text-primary:#e8e8e8;--text-secondary:#a0a0a0;--text-tertiary:#707070;--border-secondary:rgba(255,255,255,0.15);--border-tertiary:rgba(255,255,255,0.08)}}
body{font-family:var(--font-sans);background:var(--bg-secondary);color:var(--text-primary);min-height:100vh;padding-bottom:80px}
.header{background:var(--bg-primary);border-bottom:1px solid var(--border-tertiary);padding:12px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.header-title{font-size:15px;font-weight:600}
.header-user{font-size:12px;color:var(--blue);font-weight:600;cursor:pointer}
.main{padding:16px;max-width:600px;margin:0 auto}
.nav-bottom{position:fixed;bottom:0;left:0;right:0;background:var(--bg-primary);border-top:1px solid var(--border-tertiary);display:flex;z-index:100}
.nav-btn{flex:1;padding:10px 4px 8px;text-align:center;cursor:pointer;font-size:10px;color:var(--text-secondary);border:none;background:none;font-family:var(--font-sans);transition:color .15s}
.nav-btn.ac{color:var(--blue);font-weight:600}
.nav-btn-icon{display:block;font-size:22px;margin-bottom:2px}
.card{background:var(--bg-primary);border:1px solid var(--border-tertiary);border-radius:var(--radius-lg);padding:1rem;margin-bottom:10px}
.card-click{cursor:pointer}.card-click:hover{border-color:var(--blue)}
.btn{padding:8px 16px;border-radius:var(--radius);border:1px solid var(--border-secondary);background:var(--bg-primary);font-size:13px;cursor:pointer;color:var(--text-primary);font-family:var(--font-sans)}
.btn-p{background:var(--blue);color:#fff;border-color:var(--blue)}
.btn-d{color:var(--red);border-color:var(--red)}
.btn-s{color:var(--green);border-color:var(--green)}
.btn-sm{padding:4px 10px;font-size:11px;width:auto}
.ipt{padding:9px 12px;border:1.5px solid var(--border-secondary);border-radius:var(--radius);background:var(--bg-primary);font-size:13px;color:var(--text-primary);font-family:var(--font-sans);width:100%}
.ipt:focus{outline:none;border-color:var(--blue)}
select.ipt{appearance:auto}textarea.ipt{resize:vertical;min-height:80px}
.fl{display:flex;flex-direction:column;gap:5px}
.fl label{font-size:12px;color:var(--text-secondary);font-weight:600}
.form-box{background:var(--bg-secondary);border:1px solid var(--border-tertiary);border-radius:var(--radius-lg);padding:1rem;margin-bottom:1rem}
.form-title{font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.04em;margin-bottom:12px}
.bd{display:inline-block;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:600}
.bd-g{background:var(--green-bg);color:var(--green)}
.bd-r{background:var(--red-bg);color:var(--red)}
.bd-a{background:var(--amber-bg);color:var(--amber)}
.bd-b{background:var(--blue-bg);color:var(--blue)}
.bd-p{background:var(--purple-bg);color:var(--purple)}
.no{text-align:center;padding:2rem;color:var(--text-secondary);font-size:13px}
.log-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:0.5px solid var(--border-tertiary);font-size:12px}
.log-row:last-child{border-bottom:none}
.av{border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;flex-shrink:0;overflow:hidden;background-size:cover;background-position:center}
.alert-card{padding:.65rem .85rem;border-radius:var(--radius);margin-bottom:6px;font-size:12px;font-weight:500}
.alert-info{background:var(--blue-bg);color:var(--blue);border-left:3px solid var(--blue)}
.alert-warn{background:var(--amber-bg);color:var(--amber);border-left:3px solid var(--amber)}
.grid{display:grid;gap:10px}
.g2{grid-template-columns:1fr 1fr}
.mc{background:var(--bg-secondary);border-radius:var(--radius);padding:.75rem;text-align:center}
.mc .v{font-size:22px;font-weight:600}
.mc .l{font-size:10px;color:var(--text-secondary);margin-top:3px}
.select-card{border:2px solid var(--border-tertiary);border-radius:var(--radius-lg);padding:14px 16px;cursor:pointer;margin-bottom:8px;background:var(--bg-primary);transition:all .15s}
.select-card:hover{border-color:var(--blue)}
.select-card.selected{border-color:var(--blue);background:var(--blue-bg)}
/* ログイン画面 */
#login-screen{position:fixed;inset:0;background:var(--bg-primary);z-index:9999;overflow-y:auto;padding:24px}
.login-wrap{width:100%;max-width:380px;margin:0 auto;padding-top:40px;padding-bottom:40px}
.login-title{font-size:22px;font-weight:700;text-align:center;margin-bottom:6px}
.login-sub{font-size:13px;color:var(--text-secondary);text-align:center;margin-bottom:28px}
.trainer-btn{display:block;width:100%;padding:14px 16px;border-radius:var(--radius-lg);border:1.5px solid var(--border-tertiary);background:var(--bg-primary);font-size:15px;font-weight:600;cursor:pointer;margin-bottom:10px;text-align:left;font-family:var(--font-sans);color:var(--text-primary);transition:all .15s}
.trainer-btn:hover{border-color:var(--blue);background:var(--blue-bg);color:var(--blue)}
</style>
</head>
<body>

<!-- ログイン画面 -->
<div id="login-screen">
  <div class="login-wrap">
    <div style="text-align:center;font-size:48px;margin-bottom:16px">🏉</div>
    <div class="login-title">トレーナーサイト</div>
    <div class="login-sub">あなたの名前を選んでください</div>
