function collectPreCheck(lastLog){
  if(!window._preCheckOpen)return null;
  var pain=parseInt((document.getElementById('pc-pain')||{}).value);
  var feeling=(document.getElementById('pc-feeling')||{}).value||'';
  var roms=[];
  for(var ri=1;ri<=window._romCount;ri++){
    var j=(document.getElementById('rom-joint-'+ri)||{}).value;
    var a=parseFloat((document.getElementById('rom-angle-'+ri)||{}).value);
    if(j&&!isNaN(a)){
      var prevRom=lastLog&&lastLog.preCheck&&lastLog.preCheck.roms?lastLog.preCheck.roms.find(function(r){return r.joint===j;}):null;
      var diff=prevRom?Math.round((a-prevRom.angle)*10)/10:null;
      roms.push({joint:j,angle:a,diff:diff});
    }
  }
  var strengths=[];
  for(var si=1;si<=window._strengthCount;si++){
    var n=(document.getElementById('str-name-'+si)||{}).value;
    var v=parseFloat((document.getElementById('str-val-'+si)||{}).value);
    if(n&&!isNaN(v)){
      var prevStr=lastLog&&lastLog.preCheck&&lastLog.preCheck.strengths?lastLog.preCheck.strengths.find(function(s){return s.name===n;}):null;
      var sdiff=prevStr?Math.round((v-prevStr.value)*10)/10:null;
      strengths.push({name:n,value:v,diff:sdiff});
    }
  }
  return{pain:isNaN(pain)?null:pain,roms:roms,strengths:strengths,feeling:feeling};
}

