function login(tid){
  var trainer=D.trainers.find(function(t){return t.id===tid;});
  if(!trainer)return;
  // PIN確認
  var pinEl=document.getElementById('pin-input');
  if(trainer.pin){
    if(!pinEl){return;}
    if(pinEl.value!==trainer.pin){
      alert('PINが間違っています');
      pinEl.value='';
      pinEl.focus();
      return;
    }
  }
  myTrainer=trainer;
  document.getElementById('login-screen').style.display='none';
  document.getElementById('header-user').textContent=myTrainer.name+'さん | ログアウト';
  go('home');
}

function logout(){
  if(!confirm('ログアウトしますか？'))return;
  myTrainer=null;
  showLogin();
}

// ===== NAVIGATION =====
function go(tab){
  curTab=tab;
  // onclick属性からタブ名を読み取って判定（順序依存をなくす）
  document.querySelectorAll('.nav-btn').forEach(function(e){
    var onclickAttr=e.getAttribute('onclick')||'';
    var m=onclickAttr.match(/go\(['"]([^'"]+)['"]\)/);
    e.classList.toggle('ac',m&&m[1]===tab);
  });
  T[tab]&&T[tab]();
}

