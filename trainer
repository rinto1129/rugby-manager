function updatePainDisplay(){
  var el=document.getElementById('pc-pain');
  var val=parseInt(el.value);
  var valEl=document.getElementById('pc-pain-val');
  var diffEl=document.getElementById('pc-pain-diff');
  if(valEl)valEl.textContent=val+'/10';
  if(diffEl){
    var prev=parseInt(el.getAttribute('data-prev')||el.defaultValue);
    var diff=val-prev;
    diffEl.textContent='前回比: '+(diff>0?'+':'')+diff;
    diffEl.style.color=diff<0?'var(--green)':diff>0?'var(--red)':'var(--text-secondary)';
  }
}

