function doSaveRehabLogTrainer(injId,hasTpl,exCount){
  var date=document.getElementById('rl-date').value;
  if(!date)return alert('日付を入力してください');
  var exercises=[];var cats=[];
  if(hasTpl){
    for(var ei=0;ei<exCount;ei++){
      var chk=document.getElementById('rl-chk-'+ei);
      var done=chk&&chk.checked;
      var exDiv=document.getElementById('rl-ex-'+ei);
      var nameEl=exDiv?exDiv.querySelector('span[style*="font-size:13px"]'):null;
      var exName=nameEl?nameEl.textContent:'';
      var catEl=exDiv?exDiv.querySelector('span[style*="border-radius:99px"]'):null;
      var cat=catEl?catEl.textContent:'';
      var sets=parseInt((document.getElementById('rl-sets-'+ei)||{}).value)||null;
      var reps=parseInt((document.getElementById('rl-reps-'+ei)||{}).value)||null;
      var cmt=(document.getElementById('rl-cmt-'+ei)||{}).value||'';
      if(done&&cat&&cats.indexOf(cat)<0)cats.push(cat);
      exercises.push({name:exName,cat:cat,sets:sets,reps:reps,comment:cmt,done:done});
    }
  } else {
    document.querySelectorAll('[id^="crit-"]').forEach(function(el){
      var ci=el.id.replace('crit-','');
      if(isNaN(parseInt(ci)))return;
      var cat=(document.getElementById('crit-cat-'+ci)||{}).value||'';
      var name=(document.getElementById('crit-name-'+ci)||{}).value||'';
      var sets=parseInt((document.getElementById('crit-sets-'+ci)||{}).value)||null;
      var reps=parseInt((document.getElementById('crit-reps-'+ci)||{}).value)||null;
      var cmt=(document.getElementById('crit-cmt-'+ci)||{}).value||'';
      if(name){exercises.push({name:name,cat:cat,sets:sets,reps:reps,comment:cmt,done:true});if(cat&&cats.indexOf(cat)<0)cats.push(cat);}
    });
  }
  var comment=(document.getElementById('rl-comment')||{}).value||'';
  var lastLog2=(D.rlog||[]).filter(function(l){return l.injId===injId;}).sort(function(a,b){return b.date.localeCompare(a.date);})[0]||null;
  var preCheck=collectPreCheck(lastLog2);
  var curSess=getCurrentMSess();
  var logRec={id:Date.now(),injId:injId,date:date,implementer:myTrainer.name,by:myTrainer.name,cats:cats,exercises:exercises,comment:comment,preCheck:preCheck,msessId:curSess?curSess.id:null,inputAt:new Date().toISOString()};
  svSafe('rlog',logRec,function(){
    // D.rlogが更新されたので最新状態で再描画
    if(!hasTpl&&exercises.length&&confirm('このメニューをテンプレとして保存しますか？')){
      goSaveAsTemplateT(injId,exercises,cats);return;
    }
    goSetNextMenuT(injId);
  });
}

function goSaveAsTemplateT(injId,exercises,cats){
  var inj=(D.i||[]).find(function(x){return x.id===injId;});if(!inj)return;
  var name=prompt('テンプレ名を入力してください：','');
  if(!name)return goSetNextMenuT(injId);
  if(!D.rtpl)D.rtpl=[];
  var newId=D.rtpl.length?Math.max.apply(null,D.rtpl.map(function(t){return t.id;}))+1:1;
  D.rtpl.push({id:newId,name:name,part:inj.part,stage:'',cats:cats,exercises:exercises,createdBy:myTrainer.name,createdAt:todayStr()});
  db.collection('appdata').doc('rtpl').set({data:JSON.stringify(D.rtpl)}).then(function(){
    alert('テンプレを保存しました ✓');goSetNextMenuT(injId);
  }).catch(function(e){console.error(e);goSetNextMenuT(injId);});
}

function goSetNextMenuT(injId){
  var inj=(D.i||[]).find(function(x){return x.id===injId;});if(!inj)return;
  var p=D.p.find(function(x){return x.id===inj.pid;});if(!p)return;
  var plan=(D.rplan||[]).find(function(x){return x.injId===injId;});
  var cur=plan?plan.tomorrowCats||[]:[];
  var h='<div style="font-size:17px;font-weight:600;margin-bottom:8px">📅 '+p.name+' の次回メニュー</div>'+
  '<div style="font-size:13px;color:var(--text-secondary);margin-bottom:14px">今日の状況を踏まえて次回のメニューを選択してください</div>'+
  '<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px">'+
  RCATS.map(function(c,ci){
    var sel=cur.indexOf(c)>=0;
    return'<div id="nmrt-'+ci+'" onclick="toggleNextMenuCatT('+ci+')" style="padding:8px 16px;border-radius:99px;border:1.5px solid '+(sel?RCAT_COLOR[c]:'var(--border-secondary)')+';background:'+(sel?RCAT_BG[c]:'var(--bg-primary)')+';color:'+(sel?RCAT_COLOR[c]:'var(--text-primary)')+';cursor:pointer;font-size:13px;font-weight:500">'+c+'</div>';
  }).join('')+'</div>'+
  '<div style="display:flex;gap:8px"><button class="btn" onclick="go(\'rehab\')">スキップ</button><button class="btn btn-p" style="flex:1" onclick="saveNextMenuT('+injId+')">保存して完了</button></div>';
  window._nextMenuCatsT=cur.slice();
  $m().innerHTML=h;
}

function toggleNextMenuCatT(ci){
  var cat=RCATS[ci];if(!cat)return;
  if(!window._nextMenuCatsT)window._nextMenuCatsT=[];
  var i=window._nextMenuCatsT.indexOf(cat);
  if(i>=0){window._nextMenuCatsT.splice(i,1);}else{window._nextMenuCatsT.push(cat);}
  var el=document.getElementById('nmrt-'+ci);if(!el)return;
  var sel=window._nextMenuCatsT.indexOf(cat)>=0;
  el.style.borderColor=sel?RCAT_COLOR[cat]:'var(--border-secondary)';
  el.style.background=sel?RCAT_BG[cat]:'var(--bg-primary)';
  el.style.color=sel?RCAT_COLOR[cat]:'var(--text-primary)';
}

function saveNextMenuT(injId){
  if(!D.rplan)D.rplan=[];
  var plan=D.rplan.find(function(x){return x.injId===injId;});
  if(!plan){plan={injId:injId,tplId:null,tomorrowCats:[]};D.rplan.push(plan);}
  plan.tomorrowCats=window._nextMenuCatsT||[];
  sv('rplan');alert('保存しました ✓');go('rehab');
}

function timeOptions(sel){
  var h='';
  for(var hh=0;hh<24;hh++){for(var mm=0;mm<60;mm+=10){
    var v=String(hh).padStart(2,'0')+':'+String(mm).padStart(2,'0');
    h+='<option'+(v===sel?' selected':'')+'>'+v+'</option>';
  }}
  return h;
}

