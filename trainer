function calcSideDiff(ti){
  var h=parseFloat((document.getElementById('rt-healthy-'+ti)||{}).value);
  var a=parseFloat((document.getElementById('rt-affected-'+ti)||{}).value);
  var el=document.getElementById('rt-diff-'+ti);if(!el)return;
  if(isNaN(h)||isNaN(a)||h===0){el.textContent='値を入力してください';el.style.background='var(--bg-secondary)';el.style.color='';return;}
  var ratio=Math.round(a/h*1000)/10;
  var passed=ratio>=85;
  var short=passed?0:Math.round((h*0.85-a)*10)/10;
  el.textContent=ratio+'% '+(passed?'✓ クリア':'✗ 未クリア（あと'+short+'必要）');
  el.style.background=passed?'var(--green-bg)':'var(--red-bg)';
  el.style.color=passed?'var(--green)':'var(--red)';
}

function doSaveRTest(injId,physCount){
  var date=document.getElementById('rt-date').value;
  if(!date)return alert('日付を入力してください');
  var physResults=[];var physPassed=true;
  var types=window._rtTestTypes||[];
  for(var ti=0;ti<physCount;ti++){
    if(types[ti]==='sidediff'){
      var h=parseFloat((document.getElementById('rt-healthy-'+ti)||{}).value);
      var a=parseFloat((document.getElementById('rt-affected-'+ti)||{}).value);
      var ratio=(!isNaN(h)&&!isNaN(a)&&h>0)?Math.round(a/h*1000)/10:0;
      var passed=ratio>=85;
      if(!passed)physPassed=false;
      physResults.push({type:'sidediff',healthy:h,affected:a,ratio:ratio,passed:passed});
    } else {
      var chk=document.getElementById('rt-action-'+ti);
      var passed2=chk&&chk.checked;
      var cmt=(document.getElementById('rt-action-cmt-'+ti)||{}).value||'';
      if(!passed2)physPassed=false;
      physResults.push({type:'action',passed:passed2,comment:cmt});
    }
  }
  var brM=parseInt((document.getElementById('rt-br-m')||{}).value)||0;
  var brS=parseInt((document.getElementById('rt-br-s')||{}).value)||0;
  var broncoTime=(brM||brS)?(brM*60+brS):null;
  var broncoTarget=window._rtBroncoTarget;
  var fitPassed=broncoTime&&broncoTarget?broncoTime<=broncoTarget:false;
  var note=(document.getElementById('rt-note')||{}).value||'';
  var rec={id:Date.now(),injId:injId,date:date,implementer:myTrainer.name,physResults:physResults,physPassed:physPassed,broncoTime:broncoTime,fitPassed:fitPassed,note:note,inputAt:new Date().toISOString()};
  db.collection('appdata').doc('rtest').get().then(function(doc){
    var latest=[];
    if(doc.exists){try{var parsed=JSON.parse(doc.data().data);if(Array.isArray(parsed))latest=parsed;}catch(e){}}
    latest.push(rec);D.rtest=latest;
    return db.collection('appdata').doc('rtest').set({data:JSON.stringify(latest)});
  }).then(function(){
    var msg='保存しました ✓\n患部テスト: '+(physPassed?'✓ クリア':'✗ 未クリア')+'\nフィットテスト: '+(fitPassed?'✓ クリア':'✗ 未クリア');
    if(physPassed&&fitPassed)msg+='\n\n🎉 全テストクリア！スタッフに承認をもらいましょう！';
    alert(msg);
    go('rehab');
  }).catch(function(e){alert('保存に失敗しました');console.error(e);});
}

