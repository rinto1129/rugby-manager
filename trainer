function doTapeSetup(){
  var date=document.getElementById('ts-date').value;
  var type=document.getElementById('ts-type').value;
  var startT=document.getElementById('ts-start').value;
  var endT=document.getElementById('ts-end').value;
  var interval=parseInt(document.getElementById('ts-interval').value)||5;
  var cap=parseInt(document.getElementById('ts-cap').value)||1;
  if(!date||startT>=endT)return alert('日付と時間を正しく入力してください（終了 > 開始）');
  if(!D.tapeslot)D.tapeslot=[];
  var count=0;
  var cur=startT;
  while(cur<endT){
    var pts=cur.split(':');var hh=parseInt(pts[0]),mm=parseInt(pts[1]);
    var nm=mm+interval;var nh=hh+Math.floor(nm/60);nm=nm%60;
    if(nh>=24)break;
    var next=String(nh).padStart(2,'0')+':'+String(nm).padStart(2,'0');
    if(next>endT)break;
    D.tapeslot.push({id:Date.now()+count*19,date:date,type:type,startTime:cur,endTime:next,capacity:cap,staff:myTrainer.name});
    count++;cur=next;
  }
  if(!count)return alert('枠が作成できませんでした。時間を確認してください。');
  sv('tapeslot');
  alert(count+'枠を作成しました ✓');
  T.tape();
}

function delMyTapeDay(date){
  if(!confirm(fmt(date)+'の自分の枠を全て削除しますか？'))return;
  // 自分の枠だけ削除
  var mySlotIds=(D.tapeslot||[]).filter(function(s){return s.date===date&&s.staff===myTrainer.name;}).map(function(s){return s.id;});
  D.tapeslot=(D.tapeslot||[]).filter(function(s){return!(s.date===date&&s.staff===myTrainer.name);});
  D.tape=(D.tape||[]).filter(function(t){return!mySlotIds.includes(t.slotId);});
  sv('tapeslot');sv('tape');
  T.tape();
}

