<!-- ローディング -->
<div id="loading-screen" style="position:fixed;inset:0;background:var(--bg-primary);z-index:9998;display:flex;align-items:center;justify-content:center;flex-direction:column">
  <div style="font-size:40px;margin-bottom:16px">🏉</div>
  <div style="font-size:15px;font-weight:600;margin-bottom:6px">トレーナーサイト</div>
  <div style="color:var(--text-secondary);font-size:13px">データを読み込んでいます...</div>
</div>

<div class="header">
  <div class="header-title">🏉 トレーナーサイト</div>
  <div class="header-user" id="header-user" onclick="logout()">ログアウト</div>
</div>

<div class="main" id="main-ct"></div>

<div class="nav-bottom">
  <button class="nav-btn ac" onclick="go('home')"><span class="nav-btn-icon">🏠</span>ホーム</button>
  <button class="nav-btn" onclick="go('tape')"><span class="nav-btn-icon">🩻</span>テーピング</button>
  <button class="nav-btn" onclick="go('rehab')"><span class="nav-btn-icon">🩹</span>リハビリ</button>
</div>

<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
<script>
firebase.initializeApp({apiKey:"AIzaSyBNBxVywJmZVb7wmWlZkppB0ESf02IPTls",authDomain:"fukuokauniv-rug.firebaseapp.com",projectId:"fukuokauniv-rug",storageBucket:"fukuokauniv-rug.firebasestorage.app",messagingSenderId:"314514138275",appId:"1:314514138275:web:b1b93406813ebaba75cb16"});
var db=firebase.firestore();
var SK={p:'rm_players',i:'rm_injuries',r:'rm_rehabs',tape:'rm_tape',tapeslot:'rm_tapeslot',trainers:'rm_trainers',rtpl:'rm_rehab_tpl',rplan:'rm_rehab_plan',rlog:'rm_rehab_log',rtest_tpl:'rm_rtest_tpl',rtest:'rm_rtest',msess:'rm_msess',injcomm:'rm_injcomm'};
var AVC=[['#B5D4F4','#0C447C'],['#9FE1CB','#085041'],['#F5C4B3','#712B13'],['#FAC775','#633806'],['#F4C0D1','#72243E'],['#C0DD97','#27500A'],['#CECBF6','#3C3489']];
var D={p:[],i:[],r:[],tape:[],tapeslot:[],trainers:[],rtpl:[],rplan:[],rlog:[],rtest_tpl:[],rtest:[],msess:[],injcomm:[]};
var myTrainer=null;
var RCATS=['ケア','ROM改善','患部外トレーニング','トレーニング','アジリティ','フィットネス','サポート','オフ'];
var RCAT_COLOR={ケア:'var(--blue)',ROM改善:'var(--green)',患部外トレーニング:'var(--amber)',トレーニング:'var(--red)',アジリティ:'var(--purple)',フィットネス:'#0891B2',サポート:'#059669',オフ:'var(--text-secondary)'};
var RCAT_BG={ケア:'var(--blue-bg)',ROM改善:'var(--green-bg)',患部外トレーニング:'var(--amber-bg)',トレーニング:'var(--red-bg)',アジリティ:'var(--purple-bg)',フィットネス:'#E0F2FE',サポート:'#D1FAE5',オフ:'var(--bg-tertiary)'};
var STG=['ウォーキング','ランニング','スプリント','ジャンプ','コンタクト以外の練習','フルコンタクト','完全復帰'];
var curTab='home';

// ===== INIT =====
var INIT_TRAINERS=[{id:1,name:'森翔太'},{id:2,name:'中野悠星'}];

function ld(){
  var keys=Object.keys(SK);
  var promises=keys.map(function(k){
    return db.collection('appdata').doc(k).get().then(function(doc){
      if(doc.exists){
        try{
          var parsed=JSON.parse(doc.data().data);
          if(Array.isArray(parsed)&&parsed.length>0)D[k]=parsed;
          else if(!Array.isArray(parsed))D[k]=parsed;
        }catch(e){console.log('parse error:',k);}
      }
    }).catch(function(e){console.log('load error:',k,e);});
  });
  return Promise.all(promises).then(function(){
    if(!D.trainers||!D.trainers.length)D.trainers=INIT_TRAINERS;
    if(!D.tape)D.tape=[];
    if(!D.tapeslot)D.tapeslot=[];
    if(!D.rtpl)D.rtpl=[];
    if(!D.rplan)D.rplan=[];
    if(!D.rlog)D.rlog=[];
    if(!D.rtest_tpl)D.rtest_tpl=[];
    if(!D.rtest)D.rtest=[];
    if(!D.msess)D.msess=[];
  });
}

function sv(k){db.collection('appdata').doc(k).set({data:JSON.stringify(D[k])}).catch(function(e){console.error('save error:',k,e);});}
function svSafe(k,newRec,callback){
  db.collection('appdata').doc(k).get().then(function(doc){
    var latest=[];
    if(doc.exists){try{var parsed=JSON.parse(doc.data().data);if(Array.isArray(parsed))latest=parsed;}catch(e){}}
    latest.push(newRec);D[k]=latest;
    return db.collection('appdata').doc(k).set({data:JSON.stringify(latest)});
  }).then(function(){if(callback)callback();}).catch(function(e){alert('保存に失敗しました');console.error(e);});
}

function todayStr(){var d=new Date();var y=d.getFullYear();var m=String(d.getMonth()+1).padStart(2,'0');var day=String(d.getDate()).padStart(2,'0');return y+'-'+m+'-'+day;}
function filterRehabList(){
  var q=(document.getElementById('rehab-search').value||'').toLowerCase().trim();
  var cards=document.querySelectorAll('.rehab-card');
  cards.forEach(function(card){
    if(!q){card.style.display='';return;}
    var txt=card.getAttribute('data-search')||'';
    card.style.display=txt.indexOf(q)>=0?'':'none';
  });
}

function toDateStr(d){var y=d.getFullYear();var m=String(d.getMonth()+1).padStart(2,'0');var day=String(d.getDate()).padStart(2,'0');return y+'-'+m+'-'+day;}
function idEq(a,b){if(a==null||b==null)return false;return a===b||String(a)===String(b);}

// ===== 怪我コメント機能（3者共有） =====
function escapeHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');}

function getCurrentUserId(role){
  if(role==='staff')return 'staff';
  if(role==='player')return typeof myPid!=='undefined'?myPid:null;
  if(role==='trainer')return (typeof myTrainer!=='undefined'&&myTrainer)?myTrainer.id:null;
  return null;
}

function getCurrentUserName(role){
  if(role==='staff')return 'スタッフ';
  if(role==='player'){var p=D.p.find(function(x){return idEq(x.id,(typeof myPid!=='undefined'?myPid:null));});return p?p.name:'選手';}
  if(role==='trainer')return (typeof myTrainer!=='undefined'&&myTrainer)?myTrainer.name:'専門学生';
  return '';
}

function renderInjComments(iid,role){
  var commentsH=renderInjCommentsListOnly(iid,role);
  return'<div class="form-box" style="margin-top:16px"><div class="form-title">💬 コメント（スタッフ・選手・専門学生で共有）</div>'+
  '<div id="injcomm-list-'+iid+'" style="max-height:300px;overflow-y:auto;margin-bottom:10px">'+commentsH+'</div>'+
  '<textarea class="ipt" id="injcomm-input-'+iid+'" placeholder="コメントを入力..." style="min-height:60px"></textarea>'+
  '<button class="btn btn-p" style="width:100%;margin-top:6px" onclick="postInjComment('+iid+',\''+role+'\')">📤 投稿する</button>'+
  '</div>';
}

function renderInjCommentsListOnly(iid,role){
  var comments=(D.injcomm||[]).filter(function(c){return idEq(c.injId,iid);}).sort(function(a,b){return (a.createdAt||'').localeCompare(b.createdAt||'');});
  var roleLabel={staff:'スタッフ',player:'選手',trainer:'専門学生'};
  var roleColor={staff:'var(--purple)',player:'var(--blue)',trainer:'var(--green)'};
  if(!comments.length)return'<div style="font-size:12px;color:var(--text-secondary);text-align:center;padding:14px">まだコメントはありません</div>';
  return comments.map(function(c){
    var label=roleLabel[c.role]||c.role||'?';
    var color=roleColor[c.role]||'var(--text-secondary)';
    var dt=c.createdAt?new Date(c.createdAt):null;
    var dateStr=dt?(toDateStr(dt)+' '+String(dt.getHours()).padStart(2,'0')+':'+String(dt.getMinutes()).padStart(2,'0')):'';
    var canDelete=c.role===role&&String(c.authorId)===String(getCurrentUserId(role));
    return'<div style="padding:8px 10px;border-radius:var(--radius);background:var(--bg-secondary);margin-bottom:6px">'+
    '<div style="display:flex;align-items:center;justify-content:space-between;font-size:11px;margin-bottom:4px">'+
    '<span><span class="bd" style="background:'+color+';color:#fff;font-size:9px">'+label+'</span> <b style="margin-left:4px">'+(c.authorName||'')+'</b></span>'+
    '<span style="color:var(--text-secondary)">'+dateStr+(canDelete?' <button class="btn btn-sm btn-d" onclick="delInjComment(\''+c.id+'\','+iid+',\''+role+'\')">削除</button>':'')+'</span>'+
    '</div>'+
    '<div style="font-size:13px;white-space:pre-wrap;word-break:break-word">'+escapeHtml(c.text||'')+'</div>'+
    '</div>';
  }).join('');
}

function postInjComment(iid,role){
  var el=document.getElementById('injcomm-input-'+iid);
  if(!el)return;
  var text=(el.value||'').trim();
  if(!text){alert('コメントを入力してください');return;}
  var newComm={
    id:'ic_'+Date.now()+'_'+Math.floor(Math.random()*1000),
    injId:iid,role:role,
    authorId:getCurrentUserId(role),
    authorName:getCurrentUserName(role),
    text:text,createdAt:new Date().toISOString()
  };
  db.collection('appdata').doc('injcomm').get().then(function(doc){
    var latest=[];if(doc.exists){try{var parsed=JSON.parse(doc.data().data);if(Array.isArray(parsed))latest=parsed;}catch(e){}}
    latest.push(newComm);D.injcomm=latest;
    return db.collection('appdata').doc('injcomm').set({data:JSON.stringify(latest)});
  }).then(function(){
    el.value='';
    var listEl=document.getElementById('injcomm-list-'+iid);
    if(listEl){listEl.innerHTML=renderInjCommentsListOnly(iid,role);listEl.scrollTop=listEl.scrollHeight;}
  }).catch(function(e){alert('投稿に失敗しました');console.error(e);});
}

function delInjComment(cid,iid,role){
  if(!confirm('このコメントを削除しますか？'))return;
  db.collection('appdata').doc('injcomm').get().then(function(doc){
    var latest=[];if(doc.exists){try{var parsed=JSON.parse(doc.data().data);if(Array.isArray(parsed))latest=parsed;}catch(e){}}
    latest=latest.filter(function(c){return!idEq(c.id,cid);});D.injcomm=latest;
    return db.collection('appdata').doc('injcomm').set({data:JSON.stringify(latest)});
  }).then(function(){
    var listEl=document.getElementById('injcomm-list-'+iid);
    if(listEl)listEl.innerHTML=renderInjCommentsListOnly(iid,role);
  }).catch(function(e){alert('削除に失敗しました');console.error(e);});
}
function fmt(d){return d?d.replace(/-/g,'/'):'−';}
function broncoFmt(sec){if(!sec&&sec!==0)return'-';var m=Math.floor(sec/60),s=Math.round(sec%60);return m+'分'+String(s).padStart(2,'0')+'秒';}
function getCurrentMSess(){var today=todayStr();return(D.msess||[]).find(function(s){return s.startDate<=today&&s.endDate>=today;})||null;}
function numStepHTML(id,min,max,oninput){
  var dec='<button type="button" onclick="numStep(&quot;'+id+'&quot;,-1,'+min+','+max+')" style="padding:8px 14px;border:none;background:var(--bg-secondary);font-size:16px;cursor:pointer">−</button>';
  var inp='<input class="ipt" type="number" id="'+id+'" min="'+min+'" max="'+max+'" style="text-align:center;border:none;border-left:1px solid var(--border-tertiary);border-right:1px solid var(--border-tertiary);border-radius:0;flex:1" oninput="'+(oninput||'')+'" placeholder="'+min+'〜'+max+'">';
  var inc='<button type="button" onclick="numStep(&quot;'+id+'&quot;,1,'+min+','+max+')" style="padding:8px 14px;border:none;background:var(--bg-secondary);font-size:16px;cursor:pointer">＋</button>';
  return'<div style="display:flex;align-items:center;gap:0;border:1.5px solid var(--border-secondary);border-radius:var(--radius);overflow:hidden">'+dec+inp+inc+'</div>';
}
function numStep(id,dir,min,max){var el=document.getElementById(id);var v=parseInt(el.value)||0;v=Math.min(max,Math.max(min,v+dir));el.value=v;el.dispatchEvent(new Event('input'));}
function avH(p,sz){
  if(!p)return'';
  var i=(p.id||0)%AVC.length;
  var ini=p.name?p.name.split(/\s+/).map(function(w){return w[0];}).join('').slice(0,2):'?';
  return p.photo?'<div class="av" style="width:'+sz+'px;height:'+sz+'px;background-image:url('+p.photo+')"></div>':'<div class="av" style="width:'+sz+'px;height:'+sz+'px;background:'+AVC[i][0]+';color:'+AVC[i][1]+';font-size:'+Math.round(sz*.35)+'px">'+ini+'</div>';
}
function $m(){return document.getElementById('main-ct');}

// ===== LOGIN =====
function showLogin(){
  var listEl=document.getElementById('trainer-list');
  var sorted=D.trainers.slice().sort(function(a,b){return a.name.localeCompare(b.name,'ja');});
  listEl.innerHTML=sorted.map(function(t){
    return'<button class="trainer-btn" onclick="selectTrainer('+t.id+')">👤 '+t.name+'</button>';
  }).join('');
  document.getElementById('login-screen').style.display='flex';
}

function selectTrainer(tid){
  var trainer=D.trainers.find(function(t){return t.id===tid;});
  if(!trainer)return;
  // PINが未設定の場合は初期設定画面へ
  if(!trainer.pin){
    showPINSetup(tid);
  } else {
    showPINEntry(tid);
  }
}

function showPINSetup(tid){
  var trainer=D.trainers.find(function(t){return t.id===tid;});
  if(!trainer)return;
  var listEl=document.getElementById('trainer-list');
  listEl.innerHTML='<div style="text-align:center;padding:20px">'+
    '<div style="font-size:18px;font-weight:600;margin-bottom:8px">'+trainer.name+'さん</div>'+
    '<div style="font-size:13px;color:var(--text-secondary);margin-bottom:16px">初回ログイン：PIN（4桁の数字）を設定してください</div>'+
    '<input class="ipt" type="password" id="pin-new" maxlength="4" pattern="[0-9]{4}" inputmode="numeric" placeholder="●●●●" style="text-align:center;font-size:24px;letter-spacing:8px;width:160px;margin-bottom:10px"><br>'+
    '<input class="ipt" type="password" id="pin-new2" maxlength="4" pattern="[0-9]{4}" inputmode="numeric" placeholder="もう一度入力" style="text-align:center;font-size:24px;letter-spacing:8px;width:160px;margin-bottom:14px"><br>'+
    '<button class="btn btn-p" style="width:160px" onclick="doSetupPIN('+tid+')">設定する</button><br>'+
    '<button class="btn" style="margin-top:8px;font-size:12px" onclick="showLogin()">← 戻る</button>'+
    '</div>';
}

function doSetupPIN(tid){
  var pin1=document.getElementById('pin-new').value;
  var pin2=document.getElementById('pin-new2').value;
  if(!/^\d{4}$/.test(pin1)){alert('PINは4桁の数字で設定してください');return;}
  if(pin1!==pin2){alert('PINが一致しません');return;}
  // 保存
  db.collection('appdata').doc('trainers').get().then(function(doc){
    var latest=[];if(doc.exists){try{var parsed=JSON.parse(doc.data().data);if(Array.isArray(parsed))latest=parsed;}catch(e){}}
